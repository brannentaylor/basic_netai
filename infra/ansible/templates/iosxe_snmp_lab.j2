{# Phase A2 — SNMPv2 RO: numbered STANDARD ACL (source = Tigger) + snmp-server RO <number>.
   Mirrors playbooks/csr_snmp.yml. Lab-only ASCII.
   Replace {{ csr_snmp_standard_acl_num }} / community in Ansible or by hand consistently.
#}
configure terminal
no snmp-server
no access-list {{ csr_snmp_standard_acl_num }}
exit
configure terminal
access-list {{ csr_snmp_standard_acl_num }} permit host {{ tigger_snmp_collector_ipv4 }}
exit
configure terminal
snmp-server community "{{ csr_snmp_ro_community }}" RO {{ csr_snmp_standard_acl_num }}
end
write memory
