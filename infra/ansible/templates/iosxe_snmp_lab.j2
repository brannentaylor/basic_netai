{# Phase A2: SNMP v2 RO; ACL restricts poll source (basic_netai lab).
   IOS rejects non-ASCII in remarks (e.g. em dash sends invalid input).
#}
{# Human copy-paste / doc mirror of playbooks/csr_snmp.yml tasks.
   Apply from configure terminal: use `exit` (one level) after the ACL, not `!` (can pop to exec).
#}
ip access-list extended {{ csr_snmp_acl_name }}
 remark SNMP RO - Tigger telemetry {{ tigger_snmp_collector_ipv4 }}
 permit udp host {{ tigger_snmp_collector_ipv4 }} any eq snmp
 deny ip any any
exit
snmp-server community {{ csr_snmp_ro_community }} RO {{ csr_snmp_acl_name }}
